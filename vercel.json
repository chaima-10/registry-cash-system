{
  "builds": [
    { 
      "src": "frontend/package.json", 
      "use": "@vercel/static-build", 
      "config": { "distDir": "dist" } 
    },
    { 
      "src": "api/**/*.js", 
      "use": "@vercel/node" 
    }
  ],
  "routes": [
    { 
      "src": "/api/auth/(.*)", 
      "dest": "/api/auth.js" 
    },
    { 
      "src": "/api/(.*)", 
      "dest": "/api/$1.js" 
    },
    { 
      "src": "/(.*)", 
      "dest": "/frontend/index.html" 
    }
  ]
}
