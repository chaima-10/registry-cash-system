generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "mysql"
  url       = env("DATABASE_URL")
  // Aiven MySQL requires SSL
  directUrl = env("DATABASE_URL")
}

model cart {
  id          Int        @id @default(autoincrement())
  userId      Int
  user        user       @relation(fields: [userId], references: [id])
  items       cartitem[]
  totalAmount Decimal    @default(0.00) @db.Decimal(10, 2)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  subtotalHT  Decimal    @default(0.00) @db.Decimal(10, 2)
  tvaAmount   Decimal    @default(0.00) @db.Decimal(10, 2)

  @@index([userId], map: "Cart_userId_fkey")
  @@map("Cart")
}

model cartitem {
  id        Int     @id @default(autoincrement())
  cartId    Int
  cart      cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId Int
  product   product @relation(fields: [productId], references: [id])
  quantity  Int
  subtotal  Decimal @db.Decimal(10, 2)
  priceTTC  Decimal @default(0.00) @db.Decimal(10, 2)
  tvaAmount Decimal @default(0.00) @db.Decimal(10, 2)
  tvaRate   Decimal @default(0.00) @db.Decimal(5, 2)

  @@index([cartId], map: "CartItem_cartId_fkey")
  @@index([productId], map: "CartItem_productId_fkey")
  @@map("CartItem")
}

model category {
  id            Int           @id @default(autoincrement())
  name          String        @unique(map: "Category_name_key")
  subcategories subcategory[]
  products      product[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("Category")
}

model product {
  id            Int          @id @default(autoincrement())
  barcode       String       @unique(map: "Product_barcode_key")
  name          String
  price         Decimal      @db.Decimal(10, 2)
  stockQuantity Int          @default(0)
  categoryId    Int?
  category      category?    @relation(fields: [categoryId], references: [id])
  subcategoryId Int?
  subcategory   subcategory? @relation(fields: [subcategoryId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  remise        Decimal      @default(0.00) @db.Decimal(5, 2)
  tva           Decimal      @default(0.00) @db.Decimal(5, 2)
  purchasePrice Decimal      @default(0.00) @db.Decimal(10, 2)
  imageUrl      String?      @db.Text
  status        String       @default("Active")
  isDeleted     Boolean      @default(false)
  saleItems     saleitem[]
  cartItems     cartitem[]

  @@index([categoryId], map: "Product_categoryId_fkey")
  @@index([subcategoryId], map: "Product_subcategoryId_fkey")
  @@map("Product")
}

model sale {
  id            Int                @id @default(autoincrement())
  userId        Int
  user          user               @relation(fields: [userId], references: [id])
  totalAmount   Decimal            @db.Decimal(10, 2)
  paymentMethod sale_paymentMethod
  createdAt     DateTime           @default(now())
  currency      String             @default("USD")
  exchangeRate  Decimal            @default(1.0000) @db.Decimal(10, 4)
  subtotalHT    Decimal            @default(0.00) @db.Decimal(10, 2)
  tvaAmount     Decimal            @default(0.00) @db.Decimal(10, 2)
  items         saleitem[]

  @@index([userId], map: "Sale_userId_fkey")
  @@map("Sale")
}

model saleitem {
  id        Int      @id @default(autoincrement())
  saleId    Int
  sale      sale     @relation(fields: [saleId], references: [id])
  productId Int? // ← add ?
  product   product? @relation(fields: [productId], references: [id]) // ← add ?
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  subtotal  Decimal  @db.Decimal(10, 2)
  priceTTC  Decimal  @default(0.00) @db.Decimal(10, 2)
  tvaAmount Decimal  @default(0.00) @db.Decimal(10, 2)
  tvaRate   Decimal  @default(0.00) @db.Decimal(5, 2)

  @@index([productId], map: "SaleItem_productId_fkey")
  @@index([saleId], map: "SaleItem_saleId_fkey")
  @@map("SaleItem")
}

model subcategory {
  id         Int       @id @default(autoincrement())
  name       String
  categoryId Int
  category   category  @relation(fields: [categoryId], references: [id])
  products   product[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([categoryId], map: "Subcategory_categoryId_fkey")
  @@map("Subcategory")
}

model user {
  id                     Int                     @id @default(autoincrement())
  username               String                  @unique(map: "User_username_key")
  password               String
  role                   user_role               @default(cashier)
  theme                  String                  @default("light")
  sales                  sale[]
  carts                  cart[]
  giveawaysCreated       giveaway[]              @relation("GiveawayCreator")
  giveawayParticipations giveawayparticipation[]
  giveawayWins           giveawaywinner[]
  fullName               String                  @default("")
  salary                 Decimal                 @default(0.00) @db.Decimal(10, 2)
  workingDays            String                  @default("")
  email                  String?                 @unique(map: "User_email_key")
  lastLogin              DateTime?
  phone                  String?
  status                 String                  @default("Active")
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@map("User")
}

enum sale_paymentMethod {
  CASH
  CARD
  VOUCHER
}

model giveaway {
  id           Int                     @id @default(autoincrement())
  title        String
  description  String?
  startDate    DateTime                @default(now())
  endDate      DateTime
  winnerCount  Int                     @default(1)
  status       giveaway_status         @default(ACTIVE)
  createdBy    Int
  creator      user                    @relation("GiveawayCreator", fields: [createdBy], references: [id])
  participants giveawayparticipation[]
  winners      giveawaywinner[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([status])
  @@index([endDate])
}

model giveawayparticipation {
  id            Int      @id @default(autoincrement())
  giveawayId    Int
  giveaway      giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  userId        Int?     // Made optional for guest participants
  user          user?    @relation(fields: [userId], references: [id])
  clientName    String?
  clientSurname String?
  clientPhone   String?
  joinedAt      DateTime @default(now())

  @@index([giveawayId])
  @@index([userId])
  @@index([clientPhone])
}

model giveawaywinner {
  id              Int                   @id @default(autoincrement())
  giveawayId      Int
  giveaway        giveaway              @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  participationId Int?                  // Link to participation record
  participation   giveawayparticipation? @relation(fields: [participationId], references: [id])
  userId          Int?                  // Made optional
  user            user?                 @relation(fields: [userId], references: [id])
  selectedAt      DateTime              @default(now())
  rank            Int                   // 1st, 2nd, 3rd winner, etc.

  @@unique([giveawayId, userId], map: "GiveawayWinner_user_giveaway_unique")
  @@index([giveawayId])
  @@index([userId])
  @@index([participationId])
}

enum giveaway_status {
  ACTIVE
  ENDED
  DRAFT
}

enum user_role {
  admin
  cashier
}
