generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  // Aiven MySQL requires SSL
  directUrl = env("DATABASE_URL")
}

model cart {
  id          Int        @id @default(autoincrement())
  userId      Int
  user        user       @relation(fields: [userId], references: [id])
  items       cartitem[]
  totalAmount Decimal    @default(0.00) @db.Decimal(10, 2)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  subtotalHT  Decimal    @default(0.00) @db.Decimal(10, 2)
  tvaAmount   Decimal    @default(0.00) @db.Decimal(10, 2)

  @@index([userId], map: "Cart_userId_fkey")
}

model cartitem {
  id        Int     @id @default(autoincrement())
  cartId    Int
  cart      cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId Int
  product   product @relation(fields: [productId], references: [id])
  quantity  Int
  subtotal  Decimal @db.Decimal(10, 2)
  priceTTC  Decimal @default(0.00) @db.Decimal(10, 2)
  tvaAmount Decimal @default(0.00) @db.Decimal(10, 2)
  tvaRate   Decimal @default(0.00) @db.Decimal(5, 2)

  @@index([cartId], map: "CartItem_cartId_fkey")
  @@index([productId], map: "CartItem_productId_fkey")
}

model category {
  id            Int           @id @default(autoincrement())
  name          String        @unique(map: "Category_name_key")
  subcategories subcategory[]
  products      product[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model product {
  id            Int         @id @default(autoincrement())
  barcode       String      @unique(map: "Product_barcode_key")
  name          String
  price         Decimal     @db.Decimal(10, 2)
  stockQuantity Int         @default(0)
  categoryId    Int?
  category      category?   @relation(fields: [categoryId], references: [id])
  subcategoryId Int?
  subcategory   subcategory? @relation(fields: [subcategoryId], references: [id])
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  remise        Decimal     @default(0.00) @db.Decimal(5, 2)
  tva           Decimal     @default(0.00) @db.Decimal(5, 2)
  purchasePrice Decimal     @default(0.00) @db.Decimal(10, 2)
  imageUrl      String?     @db.Text
  saleItems     saleitem[]
  cartItems     cartitem[]

  @@index([categoryId], map: "Product_categoryId_fkey")
  @@index([subcategoryId], map: "Product_subcategoryId_fkey")
}

model sale {
  id            Int                @id @default(autoincrement())
  userId        Int
  user          user               @relation(fields: [userId], references: [id])
  totalAmount   Decimal            @db.Decimal(10, 2)
  paymentMethod sale_paymentMethod
  createdAt     DateTime           @default(now())
  currency      String             @default("USD")
  exchangeRate  Decimal            @default(1.0000) @db.Decimal(10, 4)
  subtotalHT    Decimal            @default(0.00) @db.Decimal(10, 2)
  tvaAmount     Decimal            @default(0.00) @db.Decimal(10, 2)
  items         saleitem[]

  @@index([userId], map: "Sale_userId_fkey")
}

model saleitem {
  id        Int     @id @default(autoincrement())
  saleId    Int
  sale      sale    @relation(fields: [saleId], references: [id])
  productId Int
  product   product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)
  priceTTC  Decimal @default(0.00) @db.Decimal(10, 2)
  tvaAmount Decimal @default(0.00) @db.Decimal(10, 2)
  tvaRate   Decimal @default(0.00) @db.Decimal(5, 2)

  @@index([productId], map: "SaleItem_productId_fkey")
  @@index([saleId], map: "SaleItem_saleId_fkey")
}

model subcategory {
  id         Int       @id @default(autoincrement())
  name       String
  categoryId Int
  category   category  @relation(fields: [categoryId], references: [id])
  products   product[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([categoryId], map: "Subcategory_categoryId_fkey")
}

model user {
  id          Int       @id @default(autoincrement())
  username    String    @unique(map: "User_username_key")
  password    String
  role        user_role @default(cashier)
  theme       String    @default("light")
  sales       sale[]
  carts       cart[]
  giveawaysCreated giveaway[] @relation("GiveawayCreator")
  giveawayParticipations giveawayparticipation[]
  giveawayWins giveawaywinner[]
  fullName    String    @default("")
  salary      Decimal   @default(0.00) @db.Decimal(10, 2)
  workingDays String    @default("")
  email       String?   @unique(map: "User_email_key")
  lastLogin   DateTime?
  phone       String?
  status      String    @default("Active")
}

enum sale_paymentMethod {
  CASH
  CARD
  VOUCHER
}

model giveaway {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  startDate   DateTime @default(now())
  endDate     DateTime
  winnerCount Int      @default(1)
  status      giveaway_status @default(ACTIVE)
  createdBy   Int
  creator     user     @relation(fields: [createdBy], references: [id])
  participants giveawayparticipation[]
  winners     giveawaywinner[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([endDate])
}

model giveawayparticipation {
  id         Int      @id @default(autoincrement())
  giveawayId  Int
  giveaway    giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  userId      Int
  user        user     @relation(fields: [userId], references: [id])
  joinedAt    DateTime @default(now())

  @@unique([giveawayId, userId], map: "GiveawayParticipation_user_giveaway_unique")
  @@index([giveawayId])
  @@index([userId])
}

model giveawaywinner {
  id         Int      @id @default(autoincrement())
  giveawayId  Int
  giveaway    giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  userId      Int
  user        user     @relation(fields: [userId], references: [id])
  selectedAt  DateTime @default(now())
  rank        Int      // 1st, 2nd, 3rd winner, etc.

  @@unique([giveawayId, userId], map: "GiveawayWinner_user_giveaway_unique")
  @@index([giveawayId])
  @@index([userId])
}

enum giveaway_status {
  ACTIVE
  ENDED
  DRAFT
}

enum user_role {
  admin
  cashier
}
